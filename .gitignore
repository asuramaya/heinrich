__pycache__/
*.egg-info/
.venv/
.pytest_cache/
dist/
build/
*.pyc
.DS_Store

# Secrets — never commit R2 / S3 credentials
.env
*.env
.env.*

# Large model files
*.safetensors
*.bin
*.pt
*.pth
*.onnx
*.gguf

# But allow test fixtures (small)
!tests/fixtures/*.safetensors
!tests/fixtures/*.npz
!tests/fixtures/*.npy

# Also prevent accidental large npz outside fixtures
*.npz
!tests/fixtures/*.npz

# Experiment databases — per-run, created automatically by SignalDB()
data/*.db
data/*.db-shm
data/*.db-wal

# Experiment output — reports, ad hoc JSON, exports
# Lives in data/runs/ (gitignored) not data/ (historical evidence)
data/runs/*
!data/runs/.gitkeep

# Keep historical investigation JSON in data/ (evidence for papers, read-only)

# HF dataset cache
~/.heinrich/
src/heinrich/profile/__pycache__/frt.cpython-312.pyc
data/logs/
logs/
*.log
__pycache__/

# Agent / CLI session state (per-machine, shouldn't be versioned)
.claude/

# Build artifacts
**/.build/
**/ModuleCache/
security/

# Local MCP config (contains absolute paths)
.mcp.json
.serena/

# Playwright MCP screenshots and page snapshots
.playwright-mcp/
.playwright-cli/

# Verification PNGs from companion QA
verify_*.png

# Vendored third-party source (mast3r, mlx_lm) — multi-GB, fetched per-machine
.vendor/

# Top-level runs/ — splat builds, FLUX.2 inject outputs, training artefacts (multi-GB)
runs/

# CF companion prototype synthetic data
web/.data/
web/node_modules/
web/.wrangler/
# the viz SPA is a generated copy of src/heinrich/companion_ui.html
web/public/observatory/index.html

# Observatory R2 export staging (regenerated by heinrich publish --local-dir)
web/.r2-export/

# VitePress build output (generated from web/docs/) + deps
web/public/docs/
web/docs/node_modules/
web/docs/.vitepress/cache/
web/docs/.vitepress/dist/

# Book reading page (generated from the .tex by web/book/build.sh)
web/public/book/
